# Rentlio — used by /api/rentlio to fetch reservation availability
RENTLIO_API_BASE_URL=https://api.rentl.io/v1
RENTLIO_API_KEY=

# EmailJS — used by the booking & contact forms (src/utils/sendEmail.ts)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_USER_ID=
# Optional — defaults to https://api.emailjs.com/api/v1.0/email/send
NEXT_PUBLIC_EMAILJS_URL=
